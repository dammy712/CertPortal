model ProductPrice {
  id          String         @id @default(uuid())
  productId   String
  product     CertificateProduct @relation(fields: [productId], references: [id])
  validity    ValidityPeriod
  priceNgn    Decimal        @db.Decimal(12, 2)
  isActive    Boolean        @default(true)

  createdAt   DateTime       @default(now())

  @@unique([productId, validity])
  @@map("product_prices")
