# ─────────────────────────────────────────
# Certificate Portal - Backend Environment
# ─────────────────────────────────────────
# Copy this file to .env and fill in your values

# App
NODE_ENV=development
PORT=5000
APP_NAME="Cert Portal"
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://certuser:certpassword@localhost:5432/certportal_dev"

# JWT Secrets (use strong random strings in production)
JWT_ACCESS_SECRET=your_super_secret_access_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# 2FA
TOTP_ISSUER="CertPortal"

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="CertPortal <noreply@certportal.com>"

# AWS S3 (for file storage)
# For MVP: set STORAGE_PROVIDER=local to store files on disk (Docker volume)
# For production: set STORAGE_PROVIDER=s3 and fill in AWS credentials
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=certportal-documents

# ── Certum CA ────────────────────────────────────────────
# Partner/reseller API credentials from Certum
CERTUM_API_URL=https://api.certum.pl
CERTUM_API_KEY=your-certum-api-key
CERTUM_API_SECRET=your-certum-api-secret
CERTUM_PARTNER_ID=your-certum-partner-id

# ── GlobalSign CA ────────────────────────────────────────
# MSSL (Managed SSL) API credentials from GlobalSign
GLOBALSIGN_API_URL=https://system.globalsign.com
GLOBALSIGN_API_KEY=your-globalsign-api-key
GLOBALSIGN_API_SECRET=your-globalsign-api-secret
GLOBALSIGN_MSSL_DOMAIN=your-mssl-domain

# Redis (for queues and rate limiting)
REDIS_URL=redis://localhost:6379

# Encryption key for sensitive data (32 bytes hex)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here_change_this

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
